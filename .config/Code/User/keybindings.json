// 将键绑定放在此文件中以覆盖默认值
[
    // ======================= 历史导航 =======================
    // macOS: Cmd+Option+左/右
    {
        "key": "alt+cmd+left",
        "command": "workbench.action.navigateBack",
        "when": "canNavigateBack"
    },
    {
        "key": "alt+cmd+right",
        "command": "workbench.action.navigateForward",
        "when": "canNavigateForward"
    },
    // Windows/Linux: Alt+左/右
    {
        "key": "alt+left",
        "command": "workbench.action.navigateBack",
        "when": "canNavigateBack && !isMac"
    },
    {
        "key": "alt+right",
        "command": "workbench.action.navigateForward",
        "when": "canNavigateForward && !isMac"
    },
    // 移除默认的历史导航快捷键
    {
        "key": "ctrl+-",
        "command": "-workbench.action.navigateBack"
    },
    {
        "key": "ctrl+shift+-",
        "command": "-workbench.action.navigateForward"
    },

    // ======================= Markdown Preview Enhanced =======================
    // Cmd+K V: 使用 MPE 预览 Markdown（覆盖 VS Code 默认预览）
    {
        "key": "cmd+k v",
        "command": "markdown-preview-enhanced.openPreviewToTheSide",
        "when": "editorLangId == 'markdown'"
    },
    {
        "key": "cmd+k v",
        "command": "-markdown.showPreviewToSide",
        "when": "editorLangId == 'markdown'"
    }
]

