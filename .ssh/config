Include ~/.orbstack/ssh/config*

# 全局配置（对所有Host生效）
Host *
  # 禁用严格主机密钥检查，无需手动输入yes
  StrictHostKeyChecking no
  # 不存储已知主机密钥（空路径）
  UserKnownHostsFile /dev/null
  # Agent Forwarding
  ForwardAgent yes
  # 保持连接活跃，防止超时断开
  ServerAliveInterval 60
  ServerAliveCountMax 3
  # 复用连接，加速多次 SSH 到同一主机
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h:%p
  ControlPersist 600
  # macOS: 使用钥匙串存储密码
  AddKeysToAgent yes
  IgnoreUnknown UseKeychain
  UseKeychain yes

