{
    // ======================= C/C++ 配置 =======================
    // VSCode 使用 ms-vscode.cpptools
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.loggingLevel": "Information",
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.cppStandard": "gnu++23",
    "C_Cpp.default.cStandard": "gnu17",
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    // 指定头文件包含路径
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/**"
    ],
    "shfmt.executablePath": "shfmt",
    // zsh/shell 脚本禁用保存时格式化
    "[shellscript]": {
        "editor.formatOnSave": false
    },
    // ======================= 编辑器设置 =======================
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "editor.useTabStops": false,
    "editor.formatOnSave": true,
    "editor.inlayHints.enabled": "on",
    "editor.renderControlCharacters": true,
    "editor.guides.indentation": true,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.unicodeHighlight.allowedLocales": {
        "zh-hans": true
    },
    "workbench.editor.enablePreview": false,
    "files.exclude": {
        "**/node_modules": true,
        "**/build": false,
        "**/dist": true,
        "**/.git": true,
        "**/.vscode": false,
        "**/.vscode-server": true
    },
    // ======================= 终端设置 =======================
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.fontFamily": "Maple Mono NF CN ExtraLight",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.cursorWidth": 1,
    "workbench.colorCustomizations": {
        "terminalCursor.foreground": "#4DEEEA"
    },
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.defaultProfile.linux": "smart-shell",
    "terminal.integrated.profiles.linux": {
        "smart-shell": {
            "path": "/bin/bash",
            "args": [
                "-l",
                "-c",
                "if command -v zsh >/dev/null 2>&1; then exec zsh -l; else exec bash -l; fi"
            ]
        },
        "zsh": {
            "path": "/usr/bin/zsh",
            "args": [
                "-l"
            ]
        }
    },
    // ======================= Python 设置 ======================= 
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        }
    },
    // 禁用终端自动激活 Python 环境（避免服务器没有 conda 时报错）
    "python.terminal.activateEnvironment": false,
    "ruff.enable": true,
    "ruff.lint.enable": true,
    "ruff.format.enable": true,
    "git.ignoreRebaseWarning": true,
    // ======================= Remote SSH 自动安装插件 =======================
    "remote.SSH.defaultExtensions": [
        // 中文语言包
        "ms-ceintl.vscode-language-pack-zh-hans",
        // C/C++
        "ms-vscode.cmake-tools",
        "xaver.clang-format",
        "vadimcn.vscode-lldb",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        // Rust
        "rust-lang.rust-analyzer",
        "fill-labs.dependi",
        "tamasfe.even-better-toml",
        // Go
        "golang.go",
        // Python
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.debugpy",
        // Java/Kotlin
        "vscjava.vscode-java-pack",
        "fwcd.kotlin",
        // Lua
        "sumneko.lua",
        // Shell
        "mkhl.shfmt",
        // Markdown
        "shd101wyy.markdown-preview-enhanced",
        // Git
        "mhutchie.git-graph",
        // Docker
        "ms-azuretools.vscode-docker"
    ]
}