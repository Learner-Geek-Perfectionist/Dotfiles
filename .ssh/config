Include ~/.orbstack/ssh/config*

# 全局配置（对所有 Host 生效）
Host *
  # 忽略非 macOS 不支持的选项（避免跨平台报错）
  IgnoreUnknown UseKeychain,AddKeysToAgent
  # SSH 连接时自动将密钥加载到 Agent
  AddKeysToAgent yes
  # macOS: 从 Keychain 读取密钥密码（自动恢复密钥）
  UseKeychain yes
  # 禁用严格主机密钥检查，无需手动输入 yes
  StrictHostKeyChecking no
  # 不存储已知主机密钥（空路径）
  UserKnownHostsFile /dev/null
  # Agent Forwarding
  ForwardAgent yes
  # 保持连接活跃，防止超时断开
  ServerAliveInterval 60
  ServerAliveCountMax 3

