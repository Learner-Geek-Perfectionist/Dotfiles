{
    "model": "claude-opus-4-6",
    "permissions": {
        "allow": [
            "Bash(*)",
            "Edit(*)",
            "Write(*)",
            "Read(*)",
            "Glob(*)",
            "Grep(*)",
            "WebFetch(*)",
            "WebSearch(*)",
            "NotebookEdit(*)"
        ]
    },
    "alwaysThinkingEnabled": true,
    "skipDangerousModePermissionPrompt": true,
    "effortLevel": "high",
    "outputStyle": "Explanatory",
    "statusLine": {
        "type": "command",
        "command": "~/.claude/statusline.sh"
    }
}
