{
    "permissions": {},
    "model": "opus[1m]",
    "outputStyle": "Explanatory",
    "language": "中文",
    "alwaysThinkingEnabled": true,
    "skipDangerousModePermissionPrompt": true,
    "effortLevel": "high",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/check-file-deps.sh"
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/sync-dotfile.sh",
                        "statusMessage": "Syncing dotfile to ~/..."
                    }
                ]
            }
        ]
    }
}
