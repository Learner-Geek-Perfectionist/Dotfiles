# Home 基础 pixi 环境（所有项目的 fallback）
# direnv 会在进入任何子目录时自动加载此环境

# 激活 home 的 pixi 环境
[[ -f "$HOME/pixi.toml" ]] && eval "$(pixi shell-hook --manifest-path "$HOME")"

# PATH 去重（pixi shell-hook 可能添加重复路径；用冒号作分隔符，不受含空格路径影响）
PATH=$(printf '%s' "$PATH" | awk -v RS=: -v ORS=: '!seen[$0]++' | sed 's/:$//')
export PATH

# p10k anaconda segment 需要这些变量才会显示环境名
export CONDA_DEFAULT_ENV="home"
export CONDA_SHLVL=1

# 修复 pixi shell-hook 覆盖的 HOST 变量（p10k 需要正确的主机名）
export HOST=$(hostname -s 2>/dev/null || hostname)


